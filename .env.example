# ==========================================
# CREDENCIAIS DA API VERDANADESK (OAUTH2)
# ==========================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env — ele está no .gitignore.

# URL base da API versionada (ex: https://seu-servidor.verdanadesk.com/api.php/v2.3)
API_URL=https://seu-servidor.verdanadesk.com/api.php/v2.3

# Client ID e Client Secret registrados na plataforma Verdanadesk
OAUTH_CLIENT_ID=seu_client_id_aqui
OAUTH_CLIENT_SECRET=seu_client_secret_aqui

# Credenciais do usuário de integração
OAUTH_USERNAME=usuario@empresa.com
OAUTH_PASSWORD=sua_senha_aqui

# (Opcional) URL do endpoint de token OAuth2.
# Se omitido, é derivado automaticamente de API_URL substituindo /vX.Y por /token.
# Exemplo: https://seu-servidor.verdanadesk.com/api.php/token
# OAUTH_TOKEN_URL=

# ==========================================
# REGRAS DE NEGÓCIO E CONFIGURAÇÕES
# ==========================================

# IDs das categorias de contratação no GLPI (separados por vírgula)
# Para descobrir o ID: abra um chamado da categoria e veja o número na URL
CATEGORIA_CONTRATACAO_IDS=ID1,ID2

# ID da categoria que exige controle de Termo de Responsabilidade (número único).
# Chamados nessa categoria recebem verificação automática da tarefa de termo.
# Deixe em branco para desativar (todos ficam como "Sem tarefa").
CATEGORIA_CONTRATACAO_ID_WITH_ASSETS=

# Intervalo entre varreduras em segundos (padrão: 300 = 5 minutos)
POLLING_INTERVAL=300

# Porta do servidor web (padrão: 8000)
WEB_PORT=8000

# ==========================================
# AUTENTICAÇÃO DO DASHBOARD (API KEY)
# ==========================================

# Chave de acesso ao dashboard e à API REST.
# Todos os endpoints exigem o header HTTP: X-Hub-API-Key: <valor>
# O dashboard solicita a chave automaticamente no primeiro acesso e a salva no navegador.
# Gere um valor seguro com: python -c "import secrets; print(secrets.token_urlsafe(32))"
# OBRIGATÓRIO: a API recusa todas as requisições se esta variável estiver vazia.
HUB_API_KEY=
